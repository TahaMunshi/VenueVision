# VenueVision Environment Variables
# Copy this to .env and update values for production

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fyp_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/fyp_db

# JWT Secret (IMPORTANT: Change this in production!)
JWT_SECRET=change-this-to-a-very-long-random-secret-key-in-production

# Flask Configuration
FLASK_ENV=production

# Optional: External database (for production deployment)
# Uncomment and set if using external PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/fyp_db
