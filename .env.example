# VenueVision – copy to .env and adjust as needed.
# For Docker: Compose reads this file (as .env) from the project root and passes TRIPO_API_KEY,
# HF_TOKEN, INPAINT_SPACE_URL, etc. into the app container (see docker-compose.yml).

# ----- Required for production -----
# Secret for signing JWT tokens. Change in production!
JWT_SECRET=change-this-secret-in-production

# ----- Database (optional – defaults work with docker-compose) -----
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fyp_db

# One-time copy local DB -> Render Postgres (see scripts/push_local_db_to_render.py)
# RENDER_DATABASE_URL=postgresql://USER:PASS@dpg-xxxx.REGION-postgres.render.com/fyp_db?sslmode=require

# Render (Docker): optional persistent disk for wall photos / GLBs / floor-plan files.
# Dashboard -> Web service -> Disks -> mount path: /app/server/static/persist (paid plans).
# VENUEVISION_PERSIST_STATIC=/app/server/static/persist
# Then upload a bundle from your laptop: scripts/make_static_bundle.py + curl in Render Shell (see that file).

# ----- Optional: 3D asset generation (image → .glb) -----
# Tripo3D API key (Tripo may issue tsk_ or tcli_ prefixes): https://www.tripo3d.ai
# When set, assets use Tripo v2.5 turbo + multiview-to-3D (1–4 images). Otherwise fallback to InstantMesh (single image).
# TRIPO_API_KEY=your_tsk_key_here

# HuggingFace token: only if using gated Spaces. Leave empty for public Spaces.
# HF_TOKEN=

# ----- Object removal (SAM + LaMa inpainting) -----
# Hugging Face Space for click-to-remove objects on wall images.
# INPAINT_SPACE_URL=TahaMunshi03/venuevision-inpaint

# ----- Frontend: API URL for split deployments (Vercel, Netlify, etc.) -----
# Host the React build on Vercel/Netlify (see vercel.json / netlify.toml), run Flask locally
# or in Docker, expose it with ngrok, then set this to the ngrok origin (no trailing slash):
#   VITE_API_BASE_URL=https://abc123.ngrok-free.app
# Rebuild/redeploy the frontend whenever the ngrok URL changes (free ngrok), or use a reserved domain.
# VITE_API_BASE_URL=

# ----- Optional: ngrok / public URL for mobile capture and Tripo3D -----
# When using ngrok (run: ngrok http 5000), set this to the https URL so the share/QR link on the guided capture page points to the tunnel.
# Also required for Tripo3D image-to-3D so the API can fetch your uploaded images (single or multiview). Example:
# PUBLIC_URL=https://abc123.ngrok-free.app
# PUBLIC_URL=
